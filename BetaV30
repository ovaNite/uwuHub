-- --- 4. TARGET FINDER --- --
local function IsValidEnemy(Player)
    if not Settings.TeamCheck then return true end
    if Player == LP or not Player.Team then return false end
    if Player.Team == LP.Team or Player.TeamColor == LP.TeamColor then return false end
    return true
end

local function GetClosestTarget()
    local target, shortest = nil, Settings.AimRadius
    for _, v in pairs(Players:GetPlayers()) do
        if v.Character and v.Character:FindFirstChild(Settings.AimPart) and v.Character:FindFirstChild("HumanoidRootPart") then
            if not IsValidEnemy(v) then continue end
            local dist = (LP.Character.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
            if dist > Settings.MaxDist or v.Character.Humanoid.Health <= 0 then continue end

            local pos, vis = Camera:WorldToViewportPoint(v.Character[Settings.AimPart].Position)
            if vis then
                local mDist = (Vector2.new(pos.X, pos.Y) - UIS:GetMouseLocation()).Magnitude
                if mDist < shortest then target = v; shortest = mDist end
            end
        end
    end
    return target
end

