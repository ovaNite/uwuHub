local function AddToggle(name, prop)
    local b = Instance.new("TextButton", Content); b.Size = UDim2.new(1, -10, 0, 45); b.BackgroundColor3 = Color3.fromRGB(25, 35, 25); b.Text = "  " .. name; b.TextColor3 = Color3.new(1,1,1); b.Font = "GothamBold"; b.TextXAlignment = "Left"; Janitor:AddInst(Instance.new("UICorner", b))
    b.MouseButton1Click:Connect(function() Settings[prop] = not Settings[prop] b.BackgroundColor3 = Settings[prop] and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(25, 35, 25) end)
end

local function AddSlider(name, min, max, prop)
    local f = Instance.new("Frame", Content); f.Size = UDim2.new(1, -10, 0, 55); f.BackgroundTransparency = 1
    local l = Instance.new("TextLabel", f); l.Size = UDim2.new(1, 0, 0, 20); l.Text = name .. ": " .. Settings[prop]; l.TextColor3 = Color3.new(1,1,1); l.Font = "Gotham"; l.BackgroundTransparency = 1
    local bg = Instance.new("Frame", f); bg.Size = UDim2.new(1, -10, 0, 4); bg.Position = UDim2.new(0, 5, 0, 35); bg.BackgroundColor3 = Color3.new(0.1, 0.2, 0.1)
    local fill = Instance.new("Frame", bg); fill.Size = UDim2.new((Settings[prop]-min)/(max-min), 0, 1, 0); fill.BackgroundColor3 = Color3.fromRGB(0, 255, 120)
    f.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then 
        local move = RunService.RenderStepped:Connect(function()
            local p = math.clamp((GetCorrectedMousePos().X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
            Settings[prop] = math.round(min + (p * (max - min))); l.Text = name .. ": " .. Settings[prop]; fill.Size = UDim2.new(p, 0, 1, 0)
        end)
        UIS.InputEnded:Connect(function(e) if e.UserInputType == Enum.UserInputType.MouseButton1 then move:Disconnect() end end)
    end end)
end

