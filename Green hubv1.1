-- --- [ 3. 🛡️ ANTI-LEAK PLAYER CLEANUP LOGIC ] --- --
-- Diese Funktion löscht ALLES, was mit einem Spieler zu tun hat, wenn er den Server verlässt
local function ClearPlayerAssets(player)
    pcall(function()
        -- Löscht Highlights am Charakter
        if player.Character then
            local hl = player.Character:FindFirstChild("GreenMatrixHL")
            if hl then hl:Destroy() end
        end
        -- Reset des Aimbot Targets, falls er das Ziel war
        if AICore.LockedTarget == player then
            AICore.LockedTarget = nil
        end
    end)
end

-- Verbinde Cleanup-Event
Janitor:Add(Players.PlayerRemoving:Connect(function(player)
    ClearPlayerAssets(player)
end))

-- --- [ 4. MATH & TARGETING ENGINE ] --- --
local function GetCorrectedMousePos() return UIS:GetMouseLocation() end
local function IsAlive(v) return v and v.Character and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 end
local function IsOnMyTeam(v) return Settings.TeamCheck and (v.Team == LP.Team or v.TeamColor == LP.TeamColor) end

local function GetBestTarget()
    local target, shortest = nil, Settings.AimRadius
    local mouseLoc = GetCorrectedMousePos()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LP and IsAlive(v) and not IsOnMyTeam(v) then
            local root = v.Character:FindFirstChild("HumanoidRootPart")
            if root then
                local worldDist = (LP.Character.HumanoidRootPart.Position - root.Position).Magnitude
                if worldDist <= Settings.MaxDist then
                    local pos, vis = Camera:WorldToViewportPoint(v.Character[Settings.AimPart].Position)
                    if vis then
                        local mDist = (Vector2.new(pos.X, pos.Y) - mouseLoc).Magnitude
                        if mDist < shortest then target = v; shortest = mDist end
                    end
                end
            end
        end
    end
    return target
end

