-- RE-EXECUTION PROTECTION (REINIGUNG ALTER SKRIPTE)
if _G.GreenHubLoaded then
    pcall(function() _G.UwuJanitor:Clean() end)
end

_G.GreenHubLoaded = true
local Janitor = { Connections = {}, Drawings = {}, Instances = {} }
_G.UwuJanitor = Janitor

function Janitor:Add(c) table.insert(self.Connections, c); return c end
function Janitor:AddDrawing(d) table.insert(self.Drawings, d); return d end
function Janitor:AddInst(i) table.insert(self.Instances, i); return i end
function Janitor:Clean()
    _G.GreenHubLoaded = false
    for _, c in pairs(self.Connections) do pcall(function() c:Disconnect() end) end
    for _, d in pairs(self.Drawings) do pcall(function() d:Remove() end) end
    for _, i in pairs(self.Instances) do pcall(function() i:Destroy() end) end
end

