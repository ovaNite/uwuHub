-- --- [ 3. 🛡️ ANTI-LEAK ENGINE ] --- --
local function ClearPlayerData(player)
    pcall(function()
        if player.Character then
            local hl = player.Character:FindFirstChild("RedMatrixHL")
            if hl then hl:Destroy() end
        end
        if AICore.LockedTarget == player then AICore.LockedTarget = nil end
    end)
end

-- Cleanup-Hook
Janitor:Add(Players.PlayerRemoving:Connect(ClearPlayerData))

-- --- [ 4. TARGETING ENGINE ] --- --
local function GetCorrectedMousePos() return UIS:GetMouseLocation() end
local function IsAlive(v) return v and v.Character and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 end
local function IsOnMyTeam(v) return Settings.TeamCheck and (v.Team == LP.Team or v.TeamColor == LP.TeamColor) end

local function GetBestTarget()
    local target, shortest = nil, Settings.AimRadius
    local mouseLoc = GetCorrectedMousePos()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LP and IsAlive(v) and not IsOnMyTeam(v) then
            local root = v.Character:FindFirstChild("HumanoidRootPart")
            if root and (root.Position - LP.Character.HumanoidRootPart.Position).Magnitude <= Settings.MaxDist then
                local pos, vis = Camera:WorldToViewportPoint(v.Character[Settings.AimPart].Position)
                if vis then
                    local mDist = (Vector2.new(pos.X, pos.Y) - mouseLoc).Magnitude
                    if mDist < shortest then target = v; shortest = mDist end
                end
            end
        end
    end
    return target
end

