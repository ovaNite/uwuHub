end

local function LoadConfig()
    if isfile("uwuHub_Config.json") then
        local json = readfile("uwuHub_Config.json")
        local data = HttpService:JSONDecode(json)
        for i, v in pairs(data) do
            Settings[i] = v
        end
    end
end

