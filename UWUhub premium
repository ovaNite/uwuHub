-- SLIDER FUNCTION
local function CreateSlider(parent, text, pos, startVal, max, callback)
    local label = Instance.new("TextLabel", parent)
    label.Text = text..": "..startVal
    label.Position = UDim2.new(0, 0, 0, pos)
    label.Size = UDim2.new(0, 200, 0, 20)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.new(1, 1, 1)
    label.TextXAlignment = "Left"

    local bg = Instance.new("Frame", parent)
    bg.Size = UDim2.new(0, 380, 0, 8)
    bg.Position = UDim2.new(0, 0, 0, pos + 25)
    bg.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    Instance.new("UICorner", bg)

    local fill = Instance.new("Frame", bg)
    fill.Size = UDim2.new(startVal/max, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(180, 120, 255)
    Instance.new("UICorner", fill)

    local dragging = false
    bg.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    
    RunService.RenderStepped:Connect(function()
        if dragging then
            local mx = UserInputService:GetMouseLocation().X
            local p = math.clamp((mx - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
            local val = (max > 1) and math.floor(p * max) or string.format("%.2f", p)
            if max <= 1 then val = tonumber(val) end
            fill.Size = UDim2.new(p, 0, 1, 0)
            label.Text = text..": "..val
            callback(val)
        end
    end)
end

