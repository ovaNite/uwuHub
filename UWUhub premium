-- 💾 SAVE/LOAD SYSTEM
local ConfigFile = "uwuHub_Config.json"
local function SaveConfig()
    local Data = {
        AimbotType = Settings.AimbotType, TeamCheck = Settings.TeamCheck,
        Smoothness = Settings.Smoothness, Range = Settings.Range,
        VisualRange = Settings.VisualRange, AimKey = tostring(Settings.AimKey),
        TargetPart = Settings.TargetPart, CharmsEnabled = Settings.CharmsEnabled,
        ESPEnabled = Settings.ESPEnabled, TracersEnabled = Settings.TracersEnabled,
        FOVVisible = Settings.FOVVisible
    }
    if writefile then writefile(ConfigFile, HttpService:JSONEncode(Data)) end
end

local function LoadConfig()
    if isfile and isfile(ConfigFile) then
        local Data = HttpService:JSONDecode(readfile(ConfigFile))
        for i, v in pairs(Data) do
            if i == "AimKey" then
                Settings.AimKey = Enum.KeyCode[v:gsub("Enum.KeyCode.", "")] or Enum.UserInputType[v:gsub("Enum.UserInputType.", "")]
            else Settings[i] = v end
        end
    end
end
