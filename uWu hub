-- COMPONENTS (Toggles & Sliders)
local function AddToggle(name, parent, pos, prop)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0, 220, 0, 40)
    btn.Position = pos
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.BorderSizePixel = 1
    btn.Font = "Code"
    local function update()
        btn.Text = name .. (Settings[prop] and ": AN" or ": AUS")
        btn.BackgroundColor3 = Settings[prop] and Color3.fromRGB(50, 150, 50) or Color3.fromRGB(150, 50, 50)
    end
    btn.MouseButton1Click:Connect(function() Settings[prop] = not Settings[prop] update() end)
    update()
    RunService.Heartbeat:Connect(update) -- UI-Sync nach Load
end

local function AddSlider(name, parent, pos, min, max, prop)
    local label = Instance.new("TextLabel", parent)
    label.Position = UDim2.new(0, 5, 0, pos)
    label.Size = UDim2.new(0, 200, 0, 20)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.new(1, 1, 1)
    label.Font = "Code"
    label.TextXAlignment = "Left"
    local bg = Instance.new("Frame", parent)
    bg.Size = UDim2.new(0, 450, 0, 15)
    bg.Position = UDim2.new(0, 5, 0, pos + 25)
    bg.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    local fill = Instance.new("Frame", bg)
    fill.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    local drag = false
    bg.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = true end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)
    RunService.RenderStepped:Connect(function()
        if drag then
            local p = math.clamp((UserInputService:GetMouseLocation().X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
            local val = min + (p * (max - min))
            Settings[prop] = (max > 1) and math.floor(val) or math.floor(val * 100) / 100
        end
        fill.Size = UDim2.new(math.clamp((Settings[prop] - min) / (max - min), 0, 1), 0, 1, 0)
        label.Text = name .. ": " .. Settings[prop]
    end)
end

