-- 💾 CONFIG LOGIC (FULLY FIXED)
local function SaveConfig(name)
    local filePath = FolderName .. "/" .. name .. ".json"
    local data = {
        AimbotType = Settings.AimbotType,
        TeamCheck = Settings.TeamCheck,
        Smoothness = Settings.Smoothness,
        Range = Settings.Range,
        VisualRange = Settings.VisualRange,
        AimKey = tostring(Settings.AimKey),
        TargetPart = Settings.TargetPart,
        ESPEnabled = Settings.ESPEnabled, 
        TracersEnabled = Settings.TracersEnabled,
        FOVVisible = Settings.FOVVisible,
        AimbotEnabled = Settings.AimbotEnabled
    }
    writefile(filePath, HttpService:JSONEncode(data))
end

local function LoadConfig(name)
    local filePath = FolderName .. "/" .. name .. ".json"
    if isfile(filePath) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(filePath)) end)
        if success then
            for i, v in pairs(data) do
                if i == "AimKey" then
                    local keyName = v:gsub("Enum.KeyCode.", "")
                    Settings.AimKey = Enum.KeyCode[keyName] or Enum.KeyCode.E
                else
                    Settings[i] = v
                end
            end
            return true
        end
    end
    return false
end

